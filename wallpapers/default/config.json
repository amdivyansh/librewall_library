{

  "modelFile": "model.glb",
  "modelScale": 0.5,
  "toneMapping": "Filmic",
  "toneMappingExposure": 1.0,
  "enableEnvironmentHDR": true,
  "enableBloom": true,
  "bloomStrength": 1,
  "bloomRadius": 0.5,
  "bloomThreshold": 0.3,
  "backgroundCSS": "#000000",
  "enableIdleRotation": true,
  "enableMouseAttraction": true,
  "lights": [
    {
      "type": "AmbientLight",
      "color": "#ffffff",
      "intensity": 1
    },
    {
      "type": "SpotLight",
      "color": "#ffffff",
      "intensity": 0.5,
      "position": {
        "x": 10,
        "y": 0,
        "z": 10
      },
      "angle": 30,
      "penumbra": 0.1
    },
    {
      "type": "SpotLight",
      "color": "#00aaff",
      "intensity": 0.8,
      "position": {
        "x": -10,
        "y": 0,
        "z": 10
      },
      "angle": 45,
      "penumbra": 0.1
    }
  ],
  "metadata": {
    "themeName": "Default Theme",
    "author": "Dkydivyansh",
    "authorUrl": "https://dkydivyansh.com",
    "description": "A abstract 3D model with customizable background and lighting.",
    "thumbnailImage": "image.png"
  },
  "Enable_Global_Widget": true,
  "fpsLimit": 60,
  "qualityPreset": "high"
}